   "outputs": [],
   "metadata": {}
  },
  {
   "kind": 2,
   "value": "FastTensor[vecA[mu]]; SetDisplayName[vecA, \"A\"];\nFastTensor[vecB[-mu]]; SetDisplayName[vecB, \"B\"];\nFastTensor[vecC[mu]]; SetDisplayName[vecC, \"C\"];\n\nexpr5 = vecA[mu] * vecB[-mu] * vecC[mu];\nPrint[\"Output (Linter de expresion con 3 indices mu): \"];\nCheckEinsteinNotation[expr5];",
   "languageId": "wolfram",
   "outputs": [
