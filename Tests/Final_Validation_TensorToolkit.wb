span><span class=\"wl-ps\">vbundle </span><div class=\"vscode-wolfram-wllatex-prerendered wl-lb-pending\" data-lb-id=\"lb-mrp2f2yz-fsdjyoj\" data-page-width-em=\"51\" data-latex-b64=\"XG1hdGhybXtUYW5nZW50SW50ZXJuYWx9\" style=\"opacity:0.65;transition:opacity 0.35s\"><div class=\"wl-lb-content\"><span class=\"katex-display\"><span class=\"katex\"><span class=\"katex-html\" aria-hidden=\"true\"><span class=\"base\"><span class=\"strut\" style=\"height:0.8889em;vertical-align:-0.1944em;\"></span><span class=\"mord\"><span class=\"mord mathrm\">TangentInternal</span></span></span></span></span></span></div></div><span class=\"wl-ps\">. </span><span class=\"wl-ps\"></span></div></div>",
